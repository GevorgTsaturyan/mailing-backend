JWT_SECRET=replace_this_with_a_long_random_string
APP_URL=https://serawin.net
NODE_ENV=production

# Canonical queue feature flag (Milestone 5)
# Set to true to route new campaign sends through the `jobs` table (canonical pipeline).
# Set to false (or omit) to use the legacy `send_jobs` pipeline.
# Flip to true only after validating the canonical pipeline in production.
USE_CANONICAL_QUEUE=false
